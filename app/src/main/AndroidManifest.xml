<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <!--
        Modern libxposed API 101 module. Module name and description come from android:label
        and android:description. Scope, entry class and API version are declared in
        src/main/resources/META-INF/xposed/{java_init.list,scope.list,module.prop}.
        There are no legacy xposed* metadata entries here.
    -->
    <application
        android:label="@string/app_name"
        android:description="@string/module_description" />

</manifest>
